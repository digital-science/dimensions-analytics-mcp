{
  "name": "dimensions-analytics-mcp-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "prepare": "lefthook install",
    "build": "pnpm --filter @digital-science-dsl/dimensions-analytics-mcp run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "integration:smoke": "node --import tsx apps/mcp/test/integration/run.ts",
    "integration:hosted": "node --import tsx apps/mcp/test/integration/hosted-run.ts",
    "typecheck": "tsc --build",
    "lint": "pnpm exec biome check apps/mcp/src",
    "lint:fix": "pnpm exec biome check --write apps/mcp/src",
    "format": "pnpm exec biome format --write apps/mcp/src",
    "clean": "rm -rf apps/mcp/dist",
    "changeset": "changeset",
    "version": "changeset version && pnpm install",
    "publish:packages": "tsx scripts/publish-packages.ts",
    "release": "pnpm run publish:packages"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^3.2.4",
    "lefthook": "^2.1.9",
    "tsx": "^4.22.4",
    "typescript": "catalog:",
    "vitest": "^3.2.4",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
